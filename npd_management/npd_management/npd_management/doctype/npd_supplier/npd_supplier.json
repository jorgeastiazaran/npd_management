{
    "name": "NPD Supplier",
    "doctype": "DocType",
    "module": "npd_management",
    "custom": 0,
    "autoname": "field:supplier_name",
    "title_field": "supplier_name",
    "search_fields": "supplier_name,supplier_group",
    "track_changes": 1,
    "document_type": "Master",
    "icon": "fa fa-user",
    "sort_field": "modified",
    "sort_order": "DESC",
    "fields": [
        {
            "fieldname": "basic_info",
            "fieldtype": "Section Break",
            "label": "Name and Type",
            "options": "fa fa-user"
        },
        {
            "fieldname": "supplier_name",
            "fieldtype": "Data",
            "label": "Supplier Name",
            "reqd": 1,
            "bold": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "country",
            "fieldtype": "Link",
            "label": "Country",
            "options": "Country"
        },
        {
            "fieldname": "tax_id",
            "fieldtype": "Data",
            "label": "Tax ID / RFC"
        },
        {
            "fieldname": "tax_category",
            "fieldtype": "Link",
            "label": "Tax Category",
            "options": "Tax Category"
        },
        {
            "fieldname": "tax_withholding_category",
            "fieldtype": "Link",
            "label": "Tax Withholding Category",
            "options": "Tax Withholding Category"
        },
        {
            "fieldname": "is_transporter",
            "fieldtype": "Check",
            "label": "Is Transporter",
            "default": "0"
        },
        {
            "fieldname": "is_internal_supplier",
            "fieldtype": "Check",
            "label": "Is Internal Supplier",
            "default": "0"
        },
        {
            "fieldname": "represents_company",
            "fieldtype": "Link",
            "label": "Represents Company",
            "options": "Company",
            "depends_on": "eval:doc.is_internal_supplier"
        },
        {
            "fieldname": "image",
            "fieldtype": "Attach Image",
            "label": "Image"
        },
        {
            "fieldname": "column_break0",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "supplier_group",
            "fieldtype": "Link",
            "label": "Supplier Group",
            "options": "Supplier Group",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "supplier_type",
            "fieldtype": "Select",
            "label": "Supplier Type",
            "options": "Company\nIndividual",
            "reqd": 1
        },
        {
            "fieldname": "pan",
            "fieldtype": "Data",
            "label": "PAN"
        },
        {
            "fieldname": "language",
            "fieldtype": "Link",
            "label": "Print Language",
            "options": "Language"
        },
        {
            "fieldname": "disabled",
            "fieldtype": "Check",
            "label": "Disabled",
            "default": "0"
        },
        {
            "fieldname": "warn_rfqs",
            "fieldtype": "Check",
            "label": "Warn RFQs",
            "default": "0"
        },
        {
            "fieldname": "warn_pos",
            "fieldtype": "Check",
            "label": "Warn POs",
            "default": "0"
        },
        {
            "fieldname": "prevent_rfqs",
            "fieldtype": "Check",
            "label": "Prevent RFQs",
            "default": "0"
        },
        {
            "fieldname": "prevent_pos",
            "fieldtype": "Check",
            "label": "Prevent POs",
            "default": "0"
        },
        {
            "fieldname": "section_break_7",
            "fieldtype": "Section Break",
            "label": "Currency and Price List"
        },
        {
            "fieldname": "default_currency",
            "fieldtype": "Link",
            "label": "Billing Currency",
            "options": "Currency"
        },
        {
            "fieldname": "column_break_10",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "default_price_list",
            "fieldtype": "Link",
            "label": "Price List",
            "options": "Price List"
        },
        {
            "fieldname": "section_credit_limit",
            "fieldtype": "Section Break",
            "label": "Credit Limit"
        },
        {
            "fieldname": "payment_terms",
            "fieldtype": "Link",
            "label": "Default Payment Terms Template",
            "options": "Payment Terms Template"
        },
        {
            "fieldname": "cb_21",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "on_hold",
            "fieldtype": "Check",
            "label": "Block Supplier",
            "default": "0"
        },
        {
            "fieldname": "hold_type",
            "fieldtype": "Select",
            "label": "Hold Type",
            "options": "\nAll\nInvoices\nPayments",
            "depends_on": "eval:doc.on_hold"
        },
        {
            "fieldname": "release_date",
            "fieldtype": "Date",
            "label": "Release Date",
            "depends_on": "eval:doc.on_hold",
            "description": "Leave blank if the Supplier is blocked indefinitely"
        },
        {
            "fieldname": "address_contacts",
            "fieldtype": "Section Break",
            "label": "Address and Contacts",
            "options": "fa fa-map-marker",
            "depends_on": "eval:!doc.__islocal"
        },
        {
            "fieldname": "address_html",
            "fieldtype": "HTML",
            "label": "Address HTML",
            "read_only": 1
        },
        {
            "fieldname": "column_break1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "contact_html",
            "fieldtype": "HTML",
            "label": "Contact HTML",
            "read_only": 1
        },
        {
            "fieldname": "primary_address_and_contact_detail_section",
            "fieldtype": "Section Break",
            "label": "Primary Address and Contact Detail"
        },
        {
            "fieldname": "supplier_primary_contact",
            "fieldtype": "Link",
            "label": "Supplier Primary Contact",
            "options": "Contact",
            "description": "Reselect, if the chosen contact is edited after save"
        },
        {
            "fieldname": "mobile_no",
            "fieldtype": "Read Only",
            "label": "Mobile No"
        },
        {
            "fieldname": "email_id",
            "fieldtype": "Read Only",
            "label": "Email Id"
        },
        {
            "fieldname": "column_break_44",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "supplier_primary_address",
            "fieldtype": "Link",
            "label": "Supplier Primary Address",
            "options": "Address",
            "description": "Reselect, if the chosen address is edited after save"
        },
        {
            "fieldname": "primary_address",
            "fieldtype": "Text",
            "label": "Primary Address",
            "read_only": 1
        },
        {
            "fieldname": "default_payable_accounts",
            "fieldtype": "Section Break",
            "label": "Default Payable Accounts"
        },
        {
            "fieldname": "accounts",
            "fieldtype": "Table",
            "label": "Accounts",
            "options": "Party Account",
            "description": "Mention if non-standard payable account"
        },
        {
            "fieldname": "column_break2",
            "fieldtype": "Section Break",
            "label": "More Information"
        },
        {
            "fieldname": "website",
            "fieldtype": "Data",
            "label": "Website"
        },
        {
            "fieldname": "supplier_details",
            "fieldtype": "Text",
            "label": "Supplier Details",
            "description": "Statutory info and other general information about your Supplier"
        },
        {
            "fieldname": "column_break_30",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "language_print",
            "fieldtype": "Link",
            "label": "Print Language",
            "options": "Language"
        },
        {
            "fieldname": "is_frozen",
            "fieldtype": "Check",
            "label": "Is Frozen",
            "default": "0"
        },
        {
            "fieldname": "npd_section",
            "fieldtype": "Section Break",
            "label": "NPD Evaluation"
        },
        {
            "fieldname": "evaluation_status",
            "fieldtype": "Select",
            "label": "Evaluation Status",
            "options": "Under Evaluation\nApproved\nRejected",
            "default": "Under Evaluation",
            "reqd": 1,
            "in_list_view": 1,
            "bold": 1
        },
        {
            "fieldname": "npd_notes",
            "fieldtype": "Text Editor",
            "label": "Evaluation Notes"
        },
        {
            "fieldname": "column_break_npd",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "is_promoted",
            "fieldtype": "Check",
            "label": "Promoted to Supplier",
            "default": "0",
            "read_only": 1
        },
        {
            "fieldname": "linked_supplier",
            "fieldtype": "Link",
            "label": "Linked Supplier",
            "options": "Supplier",
            "read_only": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 0,
            "cancel": 0,
            "amend": 0
        }
    ]
}