            "reqd": 1
        },
        {
            "fieldname": "items_section",
            "fieldtype": "Section Break",
            "label": "Items",
            "options": "fa fa-shopping-cart"
        },
        {
            "fieldname": "items",
            "fieldtype": "Table",
            "label": "Items",
            "options": "NPD RFQ Item",
            "reqd": 1
        },
        {
            "fieldname": "supplier_response_section",
            "fieldtype": "Section Break",
