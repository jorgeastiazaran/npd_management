        {
            "fieldname": "terms",
            "fieldtype": "Text Editor",
            "label": "Terms and Conditions"
        },
        {
            "fieldname": "printing_settings",
            "fieldtype": "Section Break",
            "label": "Printing Settings"
        },
        {
            "fieldname": "select_print_heading",
            "fieldtype": "Link",
            "label": "Print Heading",
            "options": "Print Heading"
        },
        {
            "fieldname": "letter_head",
            "fieldtype": "Link",
            "label": "Letter Head",
            "options": "Letter Head"
        },
        {
            "fieldname": "more_info",
            "fieldtype": "Section Break",
