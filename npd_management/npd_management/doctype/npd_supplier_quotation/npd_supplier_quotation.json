        },
        {
            "fieldname": "in_words",
            "fieldtype": "Data",
            "label": "In Words",
            "read_only": 1
        },
        {
            "fieldname": "terms_section_break",
            "fieldtype": "Section Break",
            "label": "Terms and Conditions",
            "options": "fa fa-legal"
        },
        {
            "fieldname": "tc_name",
            "fieldtype": "Link",
            "label": "Terms",
            "options": "Terms and Conditions"
        },
        {
            "fieldname": "terms",
            "fieldtype": "Text Editor",
            "label": "Terms and Conditions"
        },
        {
            "fieldname": "printing_settings",
            "fieldtype": "Section Break",
            "label": "Printing Settings"
        },
        {
            "fieldname": "select_print_heading",
            "fieldtype": "Link",
            "label": "Print Heading",
            "options": "Print Heading"
        },
        {
            "fieldname": "letter_head",
            "fieldtype": "Link",
            "label": "Letter Head",
            "options": "Letter Head"
        },
        {
            "fieldname": "col_break_print",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "group_same_items",
            "fieldtype": "Check",
            "label": "Group Same Items",
            "default": "0"
        },
        {
            "fieldname": "language",
            "fieldtype": "Data",
            "label": "Print Language"
        },
        {
            "fieldname": "more_info",
            "fieldtype": "Section Break",
            "label": "More Information",
            "options": "fa fa-file-text"
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "\nDraft\nSubmitted\nStopped\nCancelled\nExpired",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "col_break_more",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "is_subcontracted",
            "fieldtype": "Select",
            "label": "Is Subcontracted",
            "options": "\nYes\nNo"
        },
        {
            "fieldname": "reference_section",
            "fieldtype": "Section Break",
            "label": "Reference"
        },
        {
            "fieldname": "npd_rfq",
            "fieldtype": "Link",
            "label": "NPD RFQ",
            "options": "NPD RFQ"
        },
        {
            "fieldname": "opportunity",
            "fieldtype": "Link",
            "label": "Opportunity",
            "options": "Opportunity"
        },
        {
            "fieldname": "amended_from",
            "fieldtype": "Link",
            "label": "Amended From",
            "options": "NPD Supplier Quotation",
            "read_only": 1
        },
        {
            "fieldname": "npd_section",
            "fieldtype": "Section Break",
            "label": "NPD Status"
        },
        {
            "fieldname": "is_promoted",
            "fieldtype": "Check",
            "label": "Promoted to Supplier Quotation",
            "default": "0",
            "read_only": 1
        },
        {
            "fieldname": "linked_sq",
            "fieldtype": "Link",
            "label": "Linked Supplier Quotation",
            "options": "Supplier Quotation",
            "read_only": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        }
    ]
