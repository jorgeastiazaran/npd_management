{
    "name": "NPD Supplier Quotation",
    "doctype": "DocType",
    "module": "npd_management",
    "custom": 0,
    "autoname": "naming_series:",
    "title_field": "supplier",
    "is_submittable": 1,
    "track_changes": 1,
    "sort_field": "modified",
    "sort_order": "DESC",
    "fields": [
        {
            "fieldname": "naming_series",
            "fieldtype": "Select",
            "label": "Series",
            "options": "NPD-SQ-.YYYY.-",
            "reqd": 1
        },
        {
            "fieldname": "supplier_type",
            "fieldtype": "Select",
            "label": "Supplier Type",
            "options": "Supplier\nNPD Supplier",
            "reqd": 1,
            "default": "NPD Supplier",
            "in_list_view": 1
        },
        {
            "fieldname": "supplier",
            "fieldtype": "Dynamic Link",
            "label": "Supplier",
            "options": "supplier_type",
            "reqd": 1,
            "bold": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "col_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "company",
            "fieldtype": "Link",
            "label": "Company",
            "options": "Company",
            "reqd": 1
        },
        {
            "fieldname": "transaction_date",
            "fieldtype": "Date",
            "label": "Date",
            "reqd": 1,
            "default": "Today"
        },
        {
            "fieldname": "valid_till",
            "fieldtype": "Date",
            "label": "Valid Till"
        },
        {
            "fieldname": "quotation_number",
            "fieldtype": "Data",
            "label": "Quotation Number"
        },
        {
            "fieldname": "currency_section",
            "fieldtype": "Section Break",
            "label": "Currency and Price List"
        },
        {
            "fieldname": "currency",
            "fieldtype": "Link",
            "label": "Currency",
            "options": "Currency",
            "reqd": 1
        },
        {
            "fieldname": "conversion_rate",
            "fieldtype": "Float",
            "label": "Exchange Rate",
            "reqd": 1,
            "default": "1"
        },
        {
            "fieldname": "col_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "buying_price_list",
            "fieldtype": "Link",
            "label": "Price List",
            "options": "Price List"
        },
        {
            "fieldname": "price_list_currency",
            "fieldtype": "Link",
            "label": "Price List Currency",
            "options": "Currency",
