            "label": "Tax Calculation Note"
        },
        {
            "fieldname": "totals_section",
            "fieldtype": "Section Break",
            "label": "Totals"
        },
        {
            "fieldname": "total",
            "fieldtype": "Currency",
            "label": "Net Total",
            "options": "currency",
            "read_only": 1
        },
        {
            "fieldname": "total_taxes_and_charges",
            "fieldtype": "Currency",
            "label": "Total Taxes and Charges",
